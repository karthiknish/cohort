{
  "name": "cohorts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6"
  },
  "scripts": {
    "prepare": "husky",
    "prepush": "bun run ci:check && bun run ci:test",
    "release:gate": "node scripts/release-gate.mjs",
    "release:gate:fast": "node scripts/release-gate.mjs --skip-build",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "dev": "bun run dev:start",
    "dev:local": "convex dev --local & bun run dev:start",
    "convex:dev": "CONVEX_DEPLOYMENT=dev:grand-sparrow-698 convex dev",
    "convex:dev:local": "convex dev --local",
    "convex:deploy": "convex deploy --env-file .env.prod -y",
    "convex:deploy:dev": "CONVEX_DEPLOYMENT=dev:grand-sparrow-698 convex deploy -y",
    "convex:deploy:prod": "convex deploy --env-file .env.prod -y",
    "convex:deploy:all": "bun run convex:deploy:dev && bun run convex:deploy:prod",
    "convex:codegen": "CONVEX_DEPLOYMENT=dev:grand-sparrow-698 convex codegen",
    "convex:typecheck": "bun --bun tsc -p convex/tsconfig.json --noEmit",
    "convex:typecheck:codegen": "bun run convex:codegen && bun run convex:typecheck",
    "build": "bun run build:start",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "start": "node scripts/ensure-safe-runtime.cjs && bun run start:start",
    "lint": "bun run biome:check && oxlint -c .oxlintrc.json src convex",
    "typecheck": "bun --bun tsc -p tsconfig.json --noEmit",
    "verify:ci-env": "node scripts/verify-ci-env.mjs",
    "ci:check": "bun run biome:check && bun run typecheck && bun run convex:typecheck && oxlint -c .oxlintrc.json src convex",
    "ci:test": "vitest run",
    "ci:build": "bun run build:start",
    "test": "vitest run",
    "test:a11y": "playwright test e2e/agent-mode.a11y.spec.ts",
    "test:e2e:smoke": "playwright test e2e/smoke",
    "test:a11y:fixture": "PLAYWRIGHT_SKIP_WEB_SERVER=1 playwright test e2e/agent-mode.a11y.spec.ts --grep fixture",
    "r2:sync-svgl": "node scripts/sync-public-svgl-to-r2.mjs",
    "r2:configure-cors": "node scripts/configure-r2-cors.mjs",
    "dev:start": "vite dev --config vite.config.mts",
    "build:start": "cross-env NODE_ENV=production vite build --config vite.config.mts",
    "start:start": "bun .output/server/index.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "@convex-dev/better-auth": "0.12.5",
    "@convex-dev/r2": "^0.10.1",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@fontsource-variable/anybody": "^5.2.7",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@getbrevo/brevo": "^3.0.1",
    "@google-cloud/local-auth": "^3.0.1",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/tanstackstart-react": "^10.62.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.13",
    "@types/leaflet": "^1.9.21",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "agentation": "^2.3.2",
    "axios": "^1.18.0",
    "better-auth": "1.6.15",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.41.0",
    "convex-helpers": "^0.1.111",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.4.11",
    "dotenv": "^17.2.3",
    "driver.js": "^1.4.0",
    "emoji-picker-react": "^4.18.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.29.2",
    "google-auth-library": "^10.4.2",
    "isbot": "^5.1.43",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "livekit-client": "^2.17.2",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.359.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^9.0.3",
    "react-resizable-panels": "^4.5.3",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.0",
    "socket.io": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "unpdf": "^1.6.2",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nitro": "^3.0.260610-beta",
    "oxlint": "1.57.0",
    "react-doctor": "^0.5.6",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
