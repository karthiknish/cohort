{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "import", "typescript", "react", "react-perf", "nextjs", "jsx-a11y", "promise"],
  "jsPlugins": [
    {
      "name": "convex",
      "specifier": "@convex-dev/eslint-plugin"
    },
    {
      "name": "react-js",
      "specifier": "eslint-plugin-react"
    },
    "./oxlint/convex.cjs",
    "./oxlint/cohort.cjs"
  ],
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "next-env.d.ts",
    ".vercel/**",
    "convex/_generated/**",
    "convex/**/_generated/**",
    "dist/**",
    "oxlint/**",
    "scripts/**",
    "run-admin-script.js",
    "set-admin-direct.js",
    "test-proposal-validation.js"
  ],
  "env": {
    "browser": true,
    "node": true
  },
  "rules": {
    "eslint/no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@/app/*", "@/features/*"],
            "message": "Shared modules must stay independent of app routes and feature modules."
          }
        ]
      }
    ],
    "eslint/no-unused-vars": "off",
    "eslint/no-useless-escape": "off",
    "eslint/eqeqeq": ["warn", "smart", { "null": "ignore" }],
    "eslint/prefer-const": "warn",
    "eslint/no-console": [
      "warn",
      {
        "allow": ["warn", "error", "info", "debug", "trace", "log", "group", "groupEnd", "table", "time", "timeEnd", "count"]
      }
    ],
    "eslint/no-debugger": "error",
    "eslint/no-eval": "error",
    "eslint/no-implied-eval": "error",
    "eslint/no-throw-literal": "warn",
    "typescript/no-explicit-any": "error",
    "typescript/no-misused-promises": "warn",
    "typescript/no-unnecessary-condition": "warn",
    "typescript/consistent-type-imports": "warn",
    "typescript/no-require-imports": "warn",
    "typescript/no-floating-promises": "warn",
    "typescript/no-for-in-array": "error",
    "typescript/no-misused-spread": "warn",
    "typescript/no-base-to-string": "warn",
    "typescript/prefer-as-const": "warn",
    "typescript/no-non-null-asserted-optional-chain": "warn",
    "typescript/await-thenable": "error",
    "react/exhaustive-deps": "warn",
    "react/rules-of-hooks": "error",
    "react/no-array-index-key": "warn",
    "react/jsx-key": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/jsx-no-target-blank": "warn",
    "react/no-danger": "warn",
    "react-js/no-unstable-nested-components": "warn",
    "react-perf/jsx-no-new-function-as-prop": "warn",
    "react-perf/jsx-no-new-object-as-prop": "warn",
    "react-perf/jsx-no-jsx-as-prop": "warn",
    "nextjs/no-html-link-for-pages": "warn",
    "nextjs/no-img-element": "warn",
    "jsx-a11y/alt-text": "warn",
    "jsx-a11y/anchor-is-valid": "warn",
    "jsx-a11y/click-events-have-key-events": "warn",
    "jsx-a11y/no-static-element-interactions": "warn",
    "promise/no-callback-in-promise": "warn",
    "promise/valid-params": "warn",
    "cohort/no-direct-colors": "warn",
    "cohort/only-shadcn-components": "warn",
    "cohort/no-ad-hoc-rate-limits": "warn",
    "cohort/require-route-boundaries": "error",
    "convex-unused/no-unused-functions": "warn"
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  },
  "overrides": [
    {
      "files": ["**/convex/**/*.ts"],
      "rules": {
        "convex/require-args-validator": ["error", { "ignoreUnusedArguments": true }],
        "eslint/no-console": "off",
        "typescript/no-floating-promises": "off"
      }
    },
    {
      "files": [
        "**/*.{test,spec}.{ts,tsx}",
        "**/__tests__/**/*.{ts,tsx}",
        "**/vitest.setup.*",
        "**/test/**/*.{ts,tsx}"
      ],
      "rules": {
        "eslint/no-console": "off",
        "typescript/no-floating-promises": "off",
        "typescript/no-explicit-any": "off",
        "react/display-name": "off"
      }
    },
    {
      "files": ["src/shared/ui/trusted-html.tsx"],
      "rules": {
        "react/no-danger": "off"
      }
    },
    {
      "files": ["next.config.ts", "proxy.ts", "middleware.ts", "**/*.config.{ts,mts,cjs,mjs}"],
      "rules": {
        "eslint/no-console": "off",
        "typescript/no-floating-promises": "off"
      }
    },
    {
      "files": [
        "src/shared/**/*.{ts,tsx}",
        "src/features/**/*.{ts,tsx}",
        "src/hooks/**/*.{ts,tsx}",
        "src/lib/**/*.{ts,tsx}",
        "src/services/**/*.{ts,tsx}",
        "src/types/**/*.{ts,tsx}",
        "src/constants/**/*.{ts,tsx}",
        "src/config/**/*.{ts,tsx}",
        "src/app/**/*.{ts,tsx}"
      ],
      "rules": {
        "eslint/no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/app/*"],
                "message": "Import route logic through shared or feature modules, never from src/app."
              }
            ]
          }
        ]
      }
    }
  ]
}
